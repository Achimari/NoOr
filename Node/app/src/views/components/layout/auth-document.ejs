<!doctype html>
<html lang="<%= locale %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || "" %></title>
    <%- include("./loading-head") %>
    <% (assets.styles || []).forEach((href, index, styles) => { %>
      <link rel="stylesheet" href="<%= href %>"<%= index === styles.length - 1 ? ' onload="window.NoOrStylesReady && window.NoOrStylesReady()"' : "" %> />
    <% }) %>
  </head>
  <body data-page="<%= pageId %>">
    <%- body %>
  </body>
</html>
