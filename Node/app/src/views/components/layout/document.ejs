<!doctype html>
<html lang="<%= locale %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title><%= title || "" %></title>
    <%- include("./loading-head") %>
    <% (assets.styles || []).forEach((href, index, styles) => { %>
      <link rel="stylesheet" href="<%= href %>" <% if (index === styles.length - 1) { %>onload="window.NoOrStylesReady && window.NoOrStylesReady()"<% } %> />
    <% }) %>
    <script src="<%= assets.script %>" defer></script>
  </head>
  <body data-page="<%= pageId %>">
    <%- include("./header", { pageId }) %>
    <%- body %>
  </body>
</html>
