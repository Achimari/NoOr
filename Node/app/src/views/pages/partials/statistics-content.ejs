<main class="dashboard-page statistics-page">
  <section class="section dashboard-section statistics-section">
    <div class="container statistics-container">
      <section class="statistics-insights" aria-label="Statistics insights">
        <article class="dashboard-card statistics-insight statistics-insight-hard">
          <p class="dashboard-label">Hardest day</p>
          <p class="statistics-insight-value"><%= statistics.hardestDay.label %></p>
          <p class="statistics-insight-caption"><%= statistics.hardestDay.caption %></p>
        </article>

        <article class="dashboard-card statistics-insight statistics-insight-easy">
          <p class="dashboard-label">Easiest day</p>
          <p class="statistics-insight-value"><%= statistics.easiestDay.label %></p>
          <p class="statistics-insight-caption"><%= statistics.easiestDay.caption %></p>
        </article>
      </section>

      <section class="statistics-graphs" aria-label="Answer charts">
        <article class="dashboard-card statistics-chart-card">
          <header class="dashboard-card-head">
            <h2>No answers</h2>
            <span><%= statistics.totals.no %> total</span>
          </header>
          <div class="statistics-chart statistics-chart-no">
            <% statistics.noChart.forEach((day) => { %>
              <div class="statistics-bar-row">
                <span class="statistics-bar-label"><%= day.label %></span>
                <span class="statistics-bar-track" aria-hidden="true">
                  <span class="statistics-bar-fill" style="width: <%= day.percentage %>%"></span>
                </span>
                <span class="statistics-bar-value"><%= day.value %></span>
              </div>
            <% }) %>
          </div>
        </article>

        <article class="dashboard-card statistics-chart-card">
          <header class="dashboard-card-head">
            <h2>Yes answers</h2>
            <span><%= statistics.totals.yes %> total</span>
          </header>
          <div class="statistics-chart statistics-chart-yes">
            <% statistics.yesChart.forEach((day) => { %>
              <div class="statistics-bar-row">
                <span class="statistics-bar-label"><%= day.label %></span>
                <span class="statistics-bar-track" aria-hidden="true">
                  <span class="statistics-bar-fill" style="width: <%= day.percentage %>%"></span>
                </span>
                <span class="statistics-bar-value"><%= day.value %></span>
              </div>
            <% }) %>
          </div>
        </article>
      </section>

      <section class="dashboard-card prayer-world-card" aria-label="Our community">
        <div class="prayer-world-copy">
          <header class="dashboard-card-head">
            <div>
              <h2>Our community</h2>
              <p>Based on user time zones</p>
            </div>
            <span><%= statistics.prayerWorld.totalUsers %> users</span>
          </header>

          <div class="prayer-world-highlight">
            <p class="dashboard-label">Most active city</p>
            <p><%= statistics.prayerWorld.activeRegion %></p>
          </div>

          <div class="prayer-world-regions">
            <% statistics.prayerWorld.regions.forEach((region) => { %>
              <div class="prayer-world-region<%= region.isActive ? " active" : "" %>">
                <span><%= region.label %></span>
                <strong><%= region.count %></strong>
                <span class="prayer-world-region-track" aria-hidden="true">
                  <span style="width: <%= Math.max(region.percentage, region.count > 0 ? 8 : 0) %>%"></span>
                </span>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="prayer-world-visual" aria-hidden="true">
          <div class="prayer-globe">
            <span class="prayer-globe-shine"></span>
            <span class="prayer-globe-land prayer-globe-land-americas"></span>
            <span class="prayer-globe-land prayer-globe-land-europe"></span>
            <span class="prayer-globe-land prayer-globe-land-africa"></span>
            <span class="prayer-globe-land prayer-globe-land-asia"></span>
            <span class="prayer-globe-land prayer-globe-land-oceania"></span>
            <% statistics.prayerWorld.regions.forEach((region) => { %>
              <% if (region.count > 0) { %>
                <span class="prayer-globe-point<%= region.isActive ? " active" : "" %>" style="left: <%= region.x %>%; top: <%= region.y %>%; --point-scale: <%= region.pointScale %>"></span>
              <% } %>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="statistics-graphs statistics-patterns" aria-label="Community answer patterns">
        <% const dayShare = statistics.timeOfDayChart.find((period) => period.id === "day")?.sharePercentage || 0; %>
        <% const yesShare = statistics.answerDistributionChart.find((answer) => answer.id === "yes")?.sharePercentage || 0; %>

        <article class="dashboard-card statistics-donut-card">
          <header class="dashboard-card-head">
            <h2>Day or night</h2>
            <span><%= statistics.totals.answers %> total</span>
          </header>
          <div class="statistics-donut-layout">
            <div class="statistics-donut statistics-donut-time" style="--donut-main: <%= dayShare %>%">
              <span><%= dayShare %>%</span>
            </div>
            <div class="statistics-donut-legend">
              <% statistics.timeOfDayChart.forEach((period) => { %>
                <div class="statistics-donut-row statistics-donut-row-<%= period.tone %>">
                  <span><%= period.label %></span>
                  <strong><%= period.value %></strong>
                </div>
              <% }) %>
            </div>
          </div>
        </article>

        <article class="dashboard-card statistics-donut-card">
          <header class="dashboard-card-head">
            <h2>Yes or no</h2>
            <span><%= statistics.totals.answers %> total</span>
          </header>
          <div class="statistics-donut-layout">
            <div class="statistics-donut statistics-donut-answer" style="--donut-main: <%= yesShare %>%">
              <span><%= yesShare %>%</span>
            </div>
            <div class="statistics-donut-legend">
              <% statistics.answerDistributionChart.forEach((answer) => { %>
                <div class="statistics-donut-row statistics-donut-row-<%= answer.tone %>">
                  <span><%= answer.label %></span>
                  <strong><%= answer.value %></strong>
                </div>
              <% }) %>
            </div>
          </div>
        </article>
      </section>
    </div>
  </section>

  <%- include("../../components/layout/footer") %>
</main>
