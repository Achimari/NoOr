<main class="home-page dashboard-page" data-leaderboard data-current-user-id="<%= leaderboard.current.id %>">
  <section class="section dashboard-section">
    <div class="container dashboard-container">
      <div class="dashboard-actions" aria-label="Daily action">
        <button class="dashboard-action dashboard-action-yes" type="button" aria-pressed="false">
          <span class="dashboard-action-copy">
            <span class="dashboard-action-label">YES</span>
            <span class="dashboard-action-subtitle">I stayed strong</span>
          </span>
          <span class="dashboard-action-selected-icon" aria-hidden="true"></span>
        </button>

        <button class="dashboard-action dashboard-action-no" type="button" aria-pressed="false">
          <span class="dashboard-action-copy">
            <span class="dashboard-action-label">NO</span>
            <span class="dashboard-action-subtitle">I struggled today</span>
          </span>
          <span class="dashboard-action-selected-icon" aria-hidden="true"></span>
        </button>
      </div>

      <article class="dashboard-current" aria-live="polite">
        <div>
          <p class="dashboard-label">Best score</p>
          <p class="dashboard-value"><span data-overall-best-value>
              <%= leaderboard.overallBest?.value || 0 %>
            </span><span class="dashboard-value-unit"> Days</span></p>
        </div>
        <div>
          <p class="dashboard-label">Score holder</p>
          <p class="dashboard-value dashboard-holder-name" data-overall-best-name>
            <%= leaderboard.overallBest?.name || "No record yet" %>
          </p>
        </div>
        <div class="dashboard-week" data-current-date-key="<%= leaderboard.current.todayDateKey %>" aria-hidden="true">
          <% (leaderboard.current.weekDays || []).forEach((day)=> { %>
            <span class="dashboard-day<%= day.successful ? " active" : "" %><%= day.missed ? " missed" : "" %>" data-week-day="<%= day.dateKey %>" data-week-answer="<%= day.answer || "" %>" data-week-missed="<%= day.missed ? "true" : "false" %>"><%= day.label %></span>
            <% }) %>
        </div>
      </article>

      <aside class="dashboard-timer-card" data-check-in-timer hidden aria-live="polite">
        <div class="dashboard-timer-copy">
          <div>
            <p class="dashboard-timer-label">Next answer</p>
          </div>
          <span class="dashboard-timer-value" data-check-in-message>00:00:00</span>
        </div>
        <div class="dashboard-timer-track" role="progressbar" aria-label="Progress toward next answer" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
          <span class="dashboard-timer-progress" data-check-in-progress></span>
        </div>
      </aside>

      <section class="dashboard-card">
        <header class="dashboard-card-head">
          <h2>Leaderboard</h2>
          <span data-table-count>
            <%= leaderboard.leaders.length %> users
          </span>
        </header>

        <div class="leaderboard-table-wrap">
          <table class="leaderboard-table">
            <thead>
              <tr>
                <th scope="col"><span class="leaderboard-head-label"><%- include("../../components/ui/icon", {
                      name: "trophy" , className: "leaderboard-icon" }) %></span></th>
                <th scope="col"><span class="leaderboard-head-label"><%- include("../../components/ui/icon", {
                      name: "user" , className: "leaderboard-icon" }) %>Name</span></th>
                <th scope="col"><span class="leaderboard-head-label leaderboard-head-label-right">Streak</span></th>
              </tr>
            </thead>
            <tbody data-leaderboard-body>
              <% if (leaderboard.leaders.length) { %>
                <% leaderboard.leaders.forEach((entry)=> { %>
                  <tr<%- entry.id === leaderboard.current.id ? ' class="is-current"' : "" %>>
                    <td><span class="leaderboard-rank">
                        <%= entry.rank %>
                      </span></td>
                    <td><a class="leaderboard-user user-link" href="/customer/<%= entry.id %>"><%-
                          include("../../components/ui/icon", { name: "user" , className: "leaderboard-row-icon" }) %>
                          <%= entry.name %></a></td>
                    <td>
                      <span class="leaderboard-streak">
                        <span class="leaderboard-streak-value"><%= entry.value %> days</span>
                        <% if (entry.missedDays && entry.missedDays.count > 0) { %>
                          <span class="leaderboard-streak-separator" aria-hidden="true">·</span>
                          <% if (entry.id === leaderboard.current.id) { %>
                            <button class="leaderboard-missed-tag" type="button" data-missed-open data-missed-date="<%= entry.missedDays.nextDateKey %>" data-missed-count="<%= entry.missedDays.count %>" aria-label="Answer <%= entry.missedDays.count %> missed <%= entry.missedDays.count === 1 ? "day" : "days" %>">
                              <%= entry.missedDays.count %> missed
                            </button>
                          <% } else { %>
                            <span class="leaderboard-missed-tag is-static"><%= entry.missedDays.count %> missed</span>
                          <% } %>
                        <% } %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="3" class="leaderboard-empty">
                          <span class="table-empty-title">No streaks yet</span>
                          <span class="table-empty-hint">Answer today's question above to start the first streak.</span>
                        </td>
                      </tr>
                      <% } %>
            </tbody>
          </table>
        </div>
      </section>

    </div>
  </section>

  <%- include("../../components/layout/footer") %>
</main>
